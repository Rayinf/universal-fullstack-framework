/**
 * MES系统菜单配置
 * 根据MES需求规格书生成的完整菜单结构
 */

export interface MenuItem {
  id: string
  title: string
  path?: string
  icon?: string
  children?: MenuItem[]
  functionCode?: string // 功能编号
  hidden?: boolean // 是否隐藏
  roles?: string[] // 允许访问的角色
}

